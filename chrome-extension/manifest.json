{
  "manifest_version": 3,
  "name": "JW Sales Command — LinkedIn Scout",
  "version": "2.0",
  "description": "Captures LinkedIn profile view signals and syncs them to the Sales Command Center dashboard.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/analytics/profile-views/*",
        "https://www.linkedin.com/analytics/profile-views",
        "https://www.linkedin.com/analytics/recruiter-views/*",
        "https://www.linkedin.com/analytics/recruiter-views"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Force Sync Signals"
  }
}
